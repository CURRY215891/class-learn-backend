<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.xd.xdclasslearnbackend.mapper.CourseTypeMapper">

    <resultMap id="courseTypeResultMap" type="courseType">
        <id property="id" column="id"></id>
        <result property="name" column="name"></result>
        <result property="createdTime" column="created_time"></result>
        <result property="updatedTime" column="updated_time"></result>
        <result property="description" column="description"></result>
    </resultMap>

    <select id="findList" resultMap="courseTypeResultMap">
        select * from course_type
        <where>
            <if test="name !=null and name !=''">
                AND name like CONCAT('%',#{name},'%');
            </if>
            <if test="description !=null and description !=''">
                AND description like CONCAT('%',#{description},'%');
            </if>
        </where>
        order by created_time DESC;
    </select>
</mapper>